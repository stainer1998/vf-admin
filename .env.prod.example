DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=reemplazar-con-clave-aleatoria-segura
DEBUG=False

# Base de datos (MySQL crea usuario y DB automáticamente en el primer arranque)
DB_HOST=db
DB_PORT=3306
DB_NAME=vf_admin_prod
DB_USER=vf_user
DB_PASSWORD=reemplazar-con-contraseña-segura
DB_ROOT_PASSWORD=reemplazar-con-contraseña-root-segura

# Hosts permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=vf-admin.local,192.168.1.50
CSRF_TRUSTED_ORIGINS=http://vf-admin.local

# JWT (segundos)
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400
